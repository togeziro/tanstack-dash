  },
  "overrides": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged && tsc --noEmit"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ]
